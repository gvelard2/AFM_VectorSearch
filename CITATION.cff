    given-names: "Gabe"
    affiliation: "University of California, Berkeley"
    orcid: "https://orcid.org/0000-0002-7389-2017"
keywords:
  - atomic force microscopy
  - similarity search
  - multimodal embeddings
  - materials science
  - BiomedCLIP
  - pgvector
